default_platform(:ios)

platform :ios do
  desc "构建并上传到 TestFlight"
  lane :deploy do
    # 构建 iOS 应用
    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      export_options: {
        method: "app-store",
        signingStyle: "automatic"
      }
    )

    # 上传到 TestFlight
    upload_to_testflight(
      api_key: {
        "key_id" => ENV["KEY_ID"],
        "issuer_id" => ENV["ISSUER_ID"],
        "key" => ENV["APP_STORE_CONNECT_PRIVATE_KEY"]
      },
      beta_groups: ["Internal Testers"]
    )
  end
end
